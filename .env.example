# Optional BYOM configuration. Verion sends a bounded project outline for
# project understanding and a Context Capsule for release reasoning; it never
# sends source files, secrets, browser material, raw local memory, or another
# provider credential. API keys stay in this environment only and are never
# written to .verion/, browser state, diagnostics, or repair packets.
#
# Choose one: openai_compatible, gemini, openrouter, or ollama. `verion_ai` is
# reserved for a future hosted proxy and is intentionally unavailable in this
# local build.
# VERION_AI_PROVIDER=openai_compatible
# VERION_AI_MODEL=

# OpenAI-compatible endpoints. Use `responses` for OpenAI's Responses API;
# use `chat_completions` for an OpenAI-compatible chat-completions endpoint.
# VERION_OPENAI_COMPATIBLE_BASE_URL=https://api.openai.com/v1
# VERION_OPENAI_COMPATIBLE_API_STYLE=responses
# VERION_OPENAI_COMPATIBLE_MODEL=
# VERION_OPENAI_COMPATIBLE_API_KEY=

# Gemini. The model is required when VERION_AI_PROVIDER=gemini.
# VERION_GEMINI_MODEL=
# VERION_GEMINI_API_KEY=
# VERION_GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta

# OpenRouter. Pick a model that supports JSON-schema structured output.
# VERION_OPENROUTER_MODEL=
# VERION_OPENROUTER_API_KEY=
# VERION_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# Ollama is a local, keyless model option. Start Ollama locally, then choose a
# model that you have already pulled. Verion uses its OpenAI-compatible API.
# VERION_AI_PROVIDER=ollama
# VERION_OLLAMA_MODEL=qwen3:8b
# VERION_OLLAMA_BASE_URL=http://127.0.0.1:11434/v1

# Existing OpenAI setups continue to work without VERION_AI_PROVIDER. This
# legacy form uses the Responses API. Choose a model explicitly; Verion never
# silently assumes which model your account should use.
OPENAI_API_KEY=
VERION_OPENAI_MODEL=

# Deep Security Review works locally by default and needs no repository ID,
# database, GitHub token, or separate service configuration. It produces the
# same product-level release decision as Verify.
