# Optional. Enables a GPT-backed project thesis and release report. Verion sends
# only a bounded project outline for the thesis: framework, dependency names,
# routes, filenames, and deterministic local inferences. It never sends source
# files, secrets, browser material, local memory, or credentials for this step.
# Create an API key at https://platform.openai.com/api-keys.
OPENAI_API_KEY=

# Optional. Defaults to gpt-5.6 when omitted.
VERION_OPENAI_MODEL=gpt-5.6

# Optional Deep security review. All values stay local and are read only by the
# local Verion process. The service URL must resolve to localhost, and the
# repository identity must be explicitly approved here. Verion never sends a
# running-app URL, source files, local memory, browser material, or credentials.
# Leave the repository values empty to keep Deep security review disabled.
# Verion starts its built-in local engine automatically at http://127.0.0.1:5001.
# VERION_DEEP_SECURITY_URL is only for an approved local development override.
# The engine's MongoDB and GitHub credentials belong only in services/security/.env.
VERION_DEEP_SECURITY_URL=
VERION_DEEP_SECURITY_REPOSITORY_ID=
VERION_DEEP_SECURITY_REPOSITORY=
VERION_DEEP_SECURITY_REQUESTED_BY=
