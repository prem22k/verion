{
  "name": "verion",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "services/security"
  ],
  "bin": {
    "verion": "./bin/verion.mjs"
  },
  "scripts": {
    "dev": "tsx agent/cli.ts start",
    "dev:verion": "tsx agent/cli.ts start",
    "start": "tsx agent/cli.ts start",
    "dev:vite": "vite",
    "dev:security": "npm --workspace @verion/security-engine run dev",
    "build": "tsc -b && vite build",
    "build:security": "npm --workspace @verion/security-engine run build",
    "preview": "vite preview",
    "verify:demo": "tsx agent/run-verification.ts",
    "capture:dashboard": "tsx agent/capture-dashboard.ts",
    "discover": "tsx agent/cli.ts discover",
    "capsule": "tsx agent/cli.ts capsule",
    "verify": "tsx agent/cli.ts verify"
  },
  "dependencies": {
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@vitejs/plugin-react": "latest",
    "react": "latest",
    "react-dom": "latest",
    "simple-icons": "^16.26.0",
    "tsx": "latest",
    "vite": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "playwright": "latest",
    "typescript": "latest"
  }
}
